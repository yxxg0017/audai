# OpenAI API key used only by server-side API routes.
OPENAI_API_KEY=

# Realtime and multimodal model names will be finalized in later PRs.
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_VISION_MODEL=gpt-5.5

# Optional stable identifier for abuse monitoring. Leave empty for local development.
OPENAI_SAFETY_IDENTIFIER=
